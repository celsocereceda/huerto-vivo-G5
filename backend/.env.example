# ============================================================
# CONFIGURACIÓN DE LA BASE DE DATOS POSTGRESQL LOCAL
# ============================================================
# Reemplaza TUPASSWORD por la contraseña real de tu usuario postgres
# Si tu PostgreSQL está en otro puerto, cambia 5432

DATABASE_URL=postgresql://postgres:TUPASSWORD@localhost:5432/huerto_db

# ============================================================
# SEGURIDAD
# ============================================================
# JWT_SECRET es la "llave" para firmar tokens — usa cualquier texto largo

JWT_SECRET=huerto_comunitario_secreto_muy_largo_2025_cambialo_por_seguridad

# ============================================================
# SERVIDOR
# ============================================================
PORT=3000
NODE_ENV=development

# URL del frontend para CORS (Vite usa 5173 por defecto)
FRONTEND_URL=http://localhost:5173
